{
  "name": "fint-betaling-frontend",
  "version": "2.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run --pool=forks --maxWorkers=1",
    "coverage": "vitest run --coverage",
    "cypress": "cypress run",
    "cypress:open": "cypress open",
    "lint": "eslint ."
  },
  "dependencies": {
    "@navikt/ds-css": "^8.12.1",
    "@navikt/ds-react": "^8.12.1",
    "@react-router/node": "7.17.0",
    "@react-router/serve": "7.17.0",
    "isbot": "^5.1.42",
    "novari-frontend-components": "7.0.2",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "7.17.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "cypress": "^15.11.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.12.10",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^4.1.13",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint": "^9.39.4",
    "@eslint/js": "^9.37.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
